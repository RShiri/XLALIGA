# Rendered infographic PNGs are produced locally into laliga/output & epl/output
# (git-ignored); the tracked, published copies live in laliga_png/ & epl_png/.
laliga/output/
epl/output/

# Internal scraper cookie / matchCentre caches
laliga/matches/**/match_*_cache.json
epl/matches/**/match_*_cache.json

# Private configuration / credentials
.env

# Python caching
__pycache__/
*.py[cod]

# Local virtual environments
venv/
.venv/
env/

# Logs
*.log

# Raw WhoScored match JSONs are huge (~2MB each); the dashboards use the derived
# <league>_dashboard/matches_detail/*.js instead. Keep raw scrapes local only.
laliga/matches/20*/*.json
epl/matches/20*/*.json
laliga_dashboard/matches_detail/.calibrated
epl_dashboard/matches_detail/.calibrated
