# Rendered infographic PNGs are produced locally into laliga/output (git-ignored);
# the tracked, published copies live in laliga_png/.
laliga/output/

# Internal scraper cookie / matchCentre caches
laliga/matches/**/match_*_cache.json

# Private configuration / credentials
.env

# Python caching
__pycache__/
*.py[cod]

# Local virtual environments
venv/
.venv/
env/

# Logs
*.log

# Raw WhoScored match JSONs are huge (~2MB each); the dashboard uses the derived
# laliga_dashboard/matches_detail/*.js instead. Keep raw scrapes local only.
laliga/matches/20*/*.json
